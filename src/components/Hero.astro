          <span class="text-accent text-xs font-bold">N</span>
        </div>
        <span class="text-white/55">Xolventa &mdash; Cd. Victoria</span>
      </div>
      <a href="https://wa.me/528342550555" target="_blank" rel="noopener noreferrer" class="text-white/35 hover:text-white/75 transition-colors">
        834 255 0555
      </a>
    </div>
  </div>
</section>
