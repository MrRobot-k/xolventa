<section class="relative overflow-hidden bg-gradient-to-b from-primary to-[#0e1623] text-white">
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-[600px] h-[600px] bg-accent/8 rounded-full blur-[120px]"></div>
    <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[100px]"></div>
  </div>

  <div class="relative max-w-5xl mx-auto px-6 py-20 md:py-32">
    <div class="max-w-3xl">
      <img src="/logo-xolventa.webp" alt="Xolventa" class="w-full max-w-lg mx-0 mb-10" />

      <p class="badge text-accent mb-6">CD. VICTORIA, TAMAULIPAS</p>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.08] mb-6 text-balance text-white">
        Soluciones técnicas personalizadas para negocios de Cd. Victoria
      </h1>

      <p class="text-base md:text-lg text-white/55 max-w-2xl leading-relaxed mb-10">
        Desde sistemas de venta hasta automatizaciones con IA, desarrollo todo a tu medida. Sin plantillas genéricas.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a
          href="#contacto"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-accent text-white font-medium rounded-lg hover:bg-[#165f77] transition-colors text-sm"
        >
          Cuéntame qué necesitas
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a
          href="#servicios"
          class="inline-flex items-center justify-center gap-2 px-6 py-3.5 border border-white/15 text-white/80 font-medium rounded-lg hover:bg-white/5 hover:text-white transition-colors text-sm"
        >
          Ver servicios
        </a>
      </div>

      <div class="flex flex-wrap gap-x-8 gap-y-2 mt-14 text-sm text-white/35">
        <span>Windows &middot; macOS &middot; Linux</span>
        <span>Web &middot; Tablet &middot; Celular</span>
      </div>
    </div>
  </div>
</section>

<section class="bg-primary border-t border-white/5">
  <div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex flex-wrap justify-between items-center gap-4 text-sm">
      <div class="flex items-center gap-3">
