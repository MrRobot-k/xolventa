---
const servicios = [
  {
    numero: "01",
    titulo: "Apps personalizadas para tu negocio",
    texto: "¿Usas una app genérica que no termina de convencerte? Te construyo un sistema a tu medida: punto de venta, control de inventario, citas, clientes, o lo que tu negocio realmente necesite.",
    tags: ["Pago mensual", "Soporte incluido", "PC, tablet y celular"],
    destacado: true,
  },
  {
    numero: "02",
    titulo: "Páginas web para tu negocio",
    texto: "Tu negocio merece estar en internet. Una página donde tus clientes encuentran tus servicios, horarios y ubicación, y pueden contactarte directo.",
    tags: ["Pago único", "WhatsApp integrado"],
  },
  {
    numero: "03",
    titulo: "Automatizaciones con IA",
    texto: "Esas tareas que haces todos los días y te quitan tiempo: responder mensajes, organizar datos, generar reportes. La IA puede hacerlas por ti.",
    tags: ["Pago mensual", "Soporte continuo"],
  },
  {
    numero: "04",
    titulo: "Entrevista para tu negocio",
    texto: "Agendamos una plática sin compromiso. Me cuentas cómo trabajas y qué te quita tiempo. De ahí vemos si puedo ayudarte.",
    tags: ["Sin costo", "Presencial o remoto"],
  },
];
---
<section id="servicios" class="py-20 md:py-28 px-6 bg-background border-t border-border">
  <div class="max-w-5xl mx-auto">
    <div class="mb-14 max-w-xl">
      <p class="badge text-accent mb-4">Servicios</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Soluciones para los desafíos más comunes de los negocios locales
      </h2>
      <p class="text-muted-foreground text-sm md:text-base leading-relaxed">
        Cada negocio enfrenta desaf&iacute;os &uacute;nicos. Aqu&iacute; est&aacute;n las soluciones m&aacute;s comunes que ayudo a resolver.
      </p>
    </div>

    <div class="border-t border-border">
      {servicios.map((s) => (
        <div
          class:list={[
            "group grid md:grid-cols-[80px_1fr] gap-4 md:gap-8 py-8 md:py-10 border-b border-border transition-colors",
            s.destacado && "md:py-12"
          ]}
        >
          <div class="flex md:block items-baseline gap-3">
            <span class="font-mono-label text-2xl md:text-3xl text-muted-foreground/40 group-hover:text-accent/60 transition-colors">
              {s.numero}
            </span>
          </div>
          <div class="max-w-2xl">
            <h3 class:list={["font-semibold text-foreground mb-2", s.destacado ? "text-xl md:text-2xl" : "text-lg"]}>
              {s.titulo}
            </h3>
            <p class="text-muted-foreground text-sm md:text-base leading-relaxed mb-4">
              {s.texto}
            </p>
            <div class="flex flex-wrap gap-2">
              {s.tags.map((tag) => (
                <span class="font-mono-label text-[0.6875rem] text-muted-foreground border border-border px-2.5 py-1 rounded-md">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>